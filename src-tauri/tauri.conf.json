{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mambo Pedidos",
  "version": "0.2.7",
  "identifier": "com.mambo.pedidos",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mambo Pedidos",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Mambo Pedidos",
    "longDescription": "Gestor de catalogos y pedidos para perifericos gamer. Carga PDFs, Excels o CSVs, arma pedidos con calculo de rentabilidad automatico."
  },
  "plugins": {
    "fs": {
      "scope": ["$APPDATA/*", "$APPLOCALDATA/*", "$DOCUMENT/*", "$DOWNLOAD/*", "$HOME/*"]
    },
    "dialog": {},
    "store": {}
  }
}
